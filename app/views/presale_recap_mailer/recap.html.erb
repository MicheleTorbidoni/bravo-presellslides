<%# Short cover text (operator-edited, line breaks preserved) followed by a button
    that links to the prospect's public recap page. %>
<div style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; line-height: 1.5; color: #1f2430;">
  <%= simple_format(@body) %>

  <% if @url.present? %>
    <p style="margin: 24px 0;">
      <a href="<%= @url %>"
         style="display: inline-block; background: #1f2430; color: #ffffff; text-decoration: none; padding: 12px 20px; border-radius: 8px; font-weight: bold;">
        Apri il tuo riepilogo
      </a>
    </p>
    <p style="font-size: 12px; color: #6b7280;">
      Se il pulsante non funziona, copia questo link nel browser:<br>
      <a href="<%= @url %>" style="color: #6b7280;"><%= @url %></a>
    </p>
  <% end %>
</div>
